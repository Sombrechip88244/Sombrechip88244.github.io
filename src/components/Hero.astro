---

<section class="py-16 flex flex-col items-center text-center">
  <!-- Avatar -->
  <img src="/favicon.png" alt="Olly's avatar" class="w-40 h-40 rounded-full object-cover border border-[var(--color-border)] mb-6" />

  <h1 class="text-3xl sm:text-4xl font-bold text-[var(--color-text)] mb-3">
    Hi, I'm Olly
  </h1>

  <!-- Social links -->
  <div class="flex items-center gap-4 mb-4">
    {socials.map((social) => (
      <a
        href={social.url}
        target="_blank"
        rel="noopener noreferrer"
        aria-label={social.name}
        class="text-[var(--color-text-muted)] hover:text-[var(--color-accent)] transition-colors"
        set:html={social.svg}
      />
    ))}
  </div>

  <p class="text-base sm:text-lg text-[var(--color-text-muted)] max-w-xl">
    Building tools and applications.
  </p>
</section>
