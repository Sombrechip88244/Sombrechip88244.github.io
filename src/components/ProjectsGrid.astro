---
import ProjectCard from './ProjectCard.astro'

interface Props {
  token?: string
}

const { token } = Astro.props
---

<div id="projects-grid" class="grid grid-cols-1 sm:grid-cols-2 gap-4" data-token={token || ''}>
  <p class="text-[var(--color-text-muted)] col-span-full">Loading projects...</p>
</div>

<script>
  interface Repo {
    name: string
    description: string | null
    html_url: string
    homepage: string | null
    topics: string[]
    stargazers_count: number
    language: string | null
    fork: boolean
  }

  const username = 'Sombrechip'
  const token = (document.getElementById('projects-grid') as HTMLElement)?.dataset.token || ''

  async function fetchRepos() {
    const grid = document.getElementById('projects-grid')
    if (!grid) return

    const headers: HeadersInit = { 'Accept': 'application/vnd.github.v3+json' }
    if (token) headers['Authorization'] = `Bearer ${token}`

    try {
      const res = await fetch(
        `https://api.github.com/users/${username}/repos?sort=pushed&per_page=100`,
        { headers }
      )
      if (!res.ok) throw new Error(`GitHub API error: ${res.status}`)

      const repos: Repo[] = await res.json()
      const visible = repos.filter((r) => !r.fork && r.description)

      grid.innerHTML = visible.map((repo) => `
        <div class="card flex flex-col gap-3">
          <div class="flex items-start justify-between gap-2">
            <h3 class="text-lg font-semibold text-[var(--color-text)]">${escapeHtml(repo.name)}</h3>
            <a
              href={repo.html_url}
              target="_blank"
              rel="noopener noreferrer"
              class="shrink-0 text-[var(--color-text-muted)] hover:text-[var(--color-accent)]"
              aria-label="View on GitHub"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
                <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
              </svg>
            </a>
          </div>
          <p class="text-sm text-[var(--color-text-muted)] leading-relaxed">${escapeHtml(repo.description || '')}</p>
          ${repo.topics.length > 0 ? `
          <div class="flex flex-wrap gap-2 mt-auto">
            ${repo.topics.slice(0, 5).map((t) => `<span class="tag">${escapeHtml(t)}</span>`).join('')}
          </div>` : ''}
          ${repo.language ? `<p class="text-xs text-[var(--color-text-muted)]">${escapeHtml(repo.language)} · ★ ${repo.stargazers_count}</p>` : ''}
          <a
            href={repo.homepage || repo.html_url}
            target="_blank"
            rel="noopener noreferrer"
            class="text-sm font-medium text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] mt-2"
          >
            View Project →
          </a>
        </div>
      `).join('')
    } catch (err) {
      grid.innerHTML = `<p class="text-[var(--color-text-muted)] col-span-full">Failed to load projects. Check back later.</p>`
    }
  }

  function escapeHtml(str: string): string {
    return str
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
  }

  fetchRepos()
</script>