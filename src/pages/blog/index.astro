---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
)

function postUrl(id: string) {
  return `/blog/${id.replace(/\.md$/, '')}`
}
---

<BaseLayout
  title="Blog — Sombrechip"
  description="Writing on software development, tools, and side projects."
>
  <section>
    <div class="flex items-center justify-between mb-2">
      <h1 class="text-2xl font-bold text-[var(--color-text)]">Blog</h1>
      <a href="/rss.xml" target="_blank" rel="noopener noreferrer" class="text-sm text-[var(--color-text-muted)] hover:text-[var(--color-accent)] flex items-center gap-1">
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor"><path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19.01 7.38 20 6.18 20C4.98 20 4 19.01 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1z"/></svg>
        RSS
      </a>
    </div>
    <p class="text-[var(--color-text-muted)] mb-8">

    {posts.length === 0 ? (
      <p class="text-[var(--color-text-muted)]">No posts yet — check back soon.</p>
    ) : (
      <ul class="flex flex-col gap-6">
        {posts.map((post) => (
          <li class="border-b border-[var(--color-border)] pb-6 last:border-0">
            <article>
              <div class="flex flex-wrap items-center gap-2 mb-2 text-xs text-[var(--color-text-muted)]">
                <time datetime={post.data.date.toISOString()}>
                  {post.data.date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
                </time>
                {post.data.tags?.map((tag) => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <h2 class="text-lg font-semibold text-[var(--color-text)] mb-1">
                <a href={postUrl(post.id)} class="hover:text-[var(--color-accent)]">
                  {post.data.title}
                </a>
              </h2>
              <p class="text-sm text-[var(--color-text-muted)]">{post.data.description}</p>
              <a href={postUrl(post.id)} class="text-sm text-[var(--color-accent)] hover:text-[var(--color-accent-hover)] mt-2 inline-block">
                Read more →
              </a>
            </article>
          </li>
        ))}
      </ul>
    )}
  </section>
</BaseLayout>