---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Contact — Sombrechip"
  description="Get in touch with Sombrechip."
>
  <section class="max-w-xl">
    <h1 class="text-2xl font-bold text-[var(--color-text)] mb-2">Contact</h1>
    <p class="text-[var(--color-text-muted)] mb-8">
      The best way to reach me is through Email. I'm not on social media much.
    </p>

    <ul class="flex flex-col gap-4">
      <li>
        <a
          href="https://github.com/Sombrechip"
          target="_blank"
          rel="noopener noreferrer"
          class="flex items-center gap-3 p-4 card hover:border-[var(--color-accent)] group"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class="text-[var(--color-text-muted)] group-hover:text-[var(--color-accent)]">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
          </svg>
          <div>
            <div class="font-medium text-[var(--color-text)]">GitHub</div>
            <div class="text-sm text-[var(--color-text-muted)]">github.com/Sombrechip</div>
          </div>
        </a>
      </li>
      <li>
        <a
          href="mailto:Oliver.fildes@proton.me"
          class="flex items-center gap-3 p-4 card hover:border-[var(--color-accent)] group"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-[var(--color-text-muted)] group-hover:text-[var(--color-accent)]">
            <rect width="20" height="16" x="2" y="4" rx="2"/>
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/>
          </svg>
          <div>
            <div class="font-medium text-[var(--color-text)]">Email</div>
            <div class="text-sm text-[var(--color-text-muted)]">Oliver.fildes@proton.me</div>
          </div>
        </a>
      </li>
    </ul>
  </section>
</BaseLayout>
