---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="Resume — Sombrechip"
  description="Resume / CV for Sombrechip, software developer."
>
  <section class="max-w-2xl">
    <h1 class="text-2xl font-bold text-[var(--color-text)]">Resume</h1>
    <!-- Summary -->
    <section class="mb-8">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-[var(--color-text-muted)] mb-3">Summary</h2>
      <p class="text-[var(--color-text-muted)]">
        Student developer building web apps and CLI tools in my spare time. Focused on learning and shipping small projects.
      </p>
    </section>

    <!-- Projects -->
    <section class="mb-8">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-[var(--color-text-muted)] mb-3">Projects</h2>
      <div class="space-y-4 text-sm text-[var(--color-text-muted)]">
        <div>
          <h3 class="font-semibold text-[var(--color-text)]">DevToolkit</h3>
          <p>A CLI toolkit for automating common development tasks — scaffolding, code generation, and deployment checks.</p>
        </div>
        <div>
          <h3 class="font-semibold text-[var(--color-text)]">Portfolio Site</h3>
          <p>This site — built with Astro and Tailwind CSS, deployed via GitHub Pages.</p>
        </div>
        <div>
          <h3 class="font-semibold text-[var(--color-text)]">DataPipeline</h3>
          <p>Lightweight ETL pipeline for processing CSV and JSON datasets.</p>
        </div>
      </div>
    </section>

    <!-- Skills -->
    <section class="mb-8">
      <h2 class="text-sm font-semibold uppercase tracking-wide text-[var(--color-text-muted)] mb-3">Technical Skills</h2>
      <div class="space-y-2 text-sm text-[var(--color-text-muted)]">
        <div><span class="font-medium text-[var(--color-text)]">Languages:</span> TypeScript, JavaScript, Python, Bash</div>
        <div><span class="font-medium text-[var(--color-text)]">Frameworks:</span> Node.js, Astro, Tailwind, Express</div>
        <div><span class="font-medium text-[var(--color-text)]">Tools:</span> Git, GitHub Actions, Linux, Vite</div>
      </div>
    </section>
</BaseLayout>