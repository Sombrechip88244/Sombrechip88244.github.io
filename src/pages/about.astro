---
import BaseLayout from '../layouts/BaseLayout.astro'
import { getCollection, render } from 'astro:content'

const [about] = await getCollection('about')
const { Content } = await render(about)
---

<BaseLayout
  title="About — Sombrechip"
  description="Software developer focused on clean, reliable tools and systems."
>
  <section class="max-w-2xl">
    <h1 class="text-2xl font-bold text-[var(--color-text)] mb-8">About</h1>
    <div class="prose prose-sm sm:prose-base max-w-none
      prose-headings:text-[var(--color-text)]
      prose-p:text-[var(--color-text-muted)]
      prose-a:text-[var(--color-accent)]
      prose-a:no-underline hover:prose-a:underline
      prose-code:text-[var(--color-accent)] prose-code:bg-[var(--color-surface)] prose-code:px-1 prose-code:py-0.5 prose-code:rounded prose-code:before:content-none prose-code:after:content-none
      prose-pre:bg-[var(--color-surface)] prose-pre:border prose-pre:border-[var(--color-border)]
      prose-li:text-[var(--color-text-muted)]
      prose-hr:border-[var(--color-border)]
    ">
      <Content />
    </div>
  </section>
</BaseLayout>
