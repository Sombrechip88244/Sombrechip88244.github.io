---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout
  title="404 — Page Not Found"
  description="The page you're looking for doesn't exist."
>
  <section class="max-w-xl text-center py-16">
    <p class="text-6xl font-bold text-[var(--color-accent)] mb-4">404</p>
    <h1 class="text-2xl font-bold text-[var(--color-text)] mb-3">Page not found</h1>
    <p class="text-[var(--color-text-muted)] mb-8">
      The page you're looking for doesn't exist or has been moved.
    </p>
    <a href="/" class="btn btn-outline">Go home</a>
  </section>
</BaseLayout>