---
import BaseLayout from '../layouts/BaseLayout.astro'
import ProjectCard from '../components/ProjectCard.astro'
import { getCollection } from 'astro:content'

const [entry] = await getCollection('projects')
const projects = entry.data
---

<BaseLayout
  title="Projects — Oliver Fildes"
  description="Open source projects and experiments by Oliver Fildes."
>
  <section>
    <h1 class="text-2xl font-bold text-[var(--color-text)] mb-2">Projects</h1>
    <p class="text-[var(--color-text-muted)] mb-8">
      A collection of things I've built — tools, experiments, and side projects.
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
      {projects.map((project: { title: string; description: string; url: string; tags: string[]; repo?: string }) => (
        <ProjectCard {...project} />
      ))}
    </div>
  </section>
</BaseLayout>
