---
import BaseLayout from '../layouts/BaseLayout.astro'
import ProjectsGrid from '../components/ProjectsGrid.astro'

const token = import.meta.env.PUBLIC_GITHUB_TOKEN
---

<BaseLayout
  title="Projects — Sombrechip"
  description="Open source projects and experiments by Sombrechip."
>
  <section>
    <h1 class="text-2xl font-bold text-[var(--color-text)] mb-2">Projects</h1>
    <p class="text-[var(--color-text-muted)] mb-8">
      A collection of things I've built — tools, experiments, and side projects.
    </p>

    <ProjectsGrid token={token} />
  </section>
</BaseLayout>